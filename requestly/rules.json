[
  {
    "id": "payshield-tamper-header-001",
    "objectType": "rule",
    "ruleType": "Headers",
    "name": "PayShield - Inject Tamper Marker",
    "description": "Adds X-Requestly-Modified header to payment API requests. This triggers PayShield's tamper detection middleware and returns 402 FRAUD_FLAGGED.",
    "status": "Active",
    "pairs": [
      {
        "source": {
          "key": "Url",
          "operator": "Contains",
          "value": "payment/initiate"
        },
        "modifications": {
          "Request": [
            {
              "header": "X-Requestly-Modified",
              "value": "true",
              "type": "Add"
            }
          ]
        }
      }
    ]
  }
]
